# ─────────────────────────────────────────────────
#  BOTIFY-X — Environment Variables Template
#  Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────

# ── REQUIRED ─────────────────────────────────────
# Your session string from the Pairing Portal.
# Format: BOTIFY-X=<base64>  or  MEGA-<megaId>
SESSION_ID=BOTIFY-X=PASTE_YOUR_SESSION_STRING_HERE

# ── BOT IDENTITY ──────────────────────────────────
# Your WhatsApp number (international format, digits only)
OWNER_NUMBER=234XXXXXXXXXX

# ── OPTIONAL APIS ────────────────────────────────
# Google Gemini API key for AI chatbot feature
GEMINI_API_KEY=

# URL of the Pairing Portal (used by .pair command)
PAIRING_PORTAL_URL=

# Session secret for the Express session middleware
SESSION_SECRET=change_this_to_a_random_string

# ── DEPLOYMENT ────────────────────────────────────
# Port for the pairing portal (auto-set on Railway)
PORT=3000

# ─────────────────────────────────────────────────
#  Railway Variables (set automatically by Railway)
#  RAILWAY_SERVICE_ID, RAILWAY_ENVIRONMENT, etc.
# ─────────────────────────────────────────────────
